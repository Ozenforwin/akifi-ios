        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We analyze the last 3 months of your transactions, compute average monthly income and expenses, and layer in your active subscriptions."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Analizamos los últimos 3 meses de transacciones, calculamos ingresos y gastos mensuales promedio y añadimos tus suscripciones activas."
