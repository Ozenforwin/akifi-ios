    "forecast.howItWorks.limits.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "One-off large purchases can skew the forecast. Transfers between your own accounts are excluded. Subscription-matching transactions are removed from averages so they are not counted twice."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gastos puntuales grandes pueden distorsionar la previsión. Las transferencias entre tus cuentas están excluidas. Las transacciones que coinciden con suscripciones se eliminan del promedio para no contarlas dos veces."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Разовые крупные траты могут искажать прогноз. Переводы между своими счетами исключены. Транзакции, совпадающие с подписками, убираются из среднего, чтобы не учитываться дважды."
          }
        }
      }
    },
    "forecast.howItWorks.limits.title" : {
      "extractionState" : "manual",
      "localizations" : {
