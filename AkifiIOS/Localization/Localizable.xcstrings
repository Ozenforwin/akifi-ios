        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Коридор уверенности"
          }
        }
      }
    },
    "forecast.howItWorks.confidence.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Low — fewer than 2 months of data. Medium — 2 to 3 months. High — 4+ months."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Baja — menos de 2 meses. Media — 2 a 3 meses. Alta — 4 o más meses."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Низкая — меньше 2 месяцев данных. Средняя — 2–3 месяца. Высокая — 4+ месяцев."
          }
        }
      }
    },
    "forecast.howItWorks.confidence.title" : {
