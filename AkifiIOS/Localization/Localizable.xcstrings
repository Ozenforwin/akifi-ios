    "forecast.howItWorks.band.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The shaded area is a ±1 standard deviation range around your typical expenses. A wider band means more month-to-month variation."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El área sombreada es un rango de ±1 desviación estándar sobre tus gastos típicos. Una banda más ancha indica más variación mes a mes."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Светлая область — диапазон ±1 стандартное отклонение расходов. Чем шире коридор, тем сильнее расходы меняются от месяца к месяцу."
          }
        }
      }
    },
    "forecast.howItWorks.band.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
